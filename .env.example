# WebCentauri — production env template. Copy to .env on the server.
NODE_ENV=production
PORT=3000
VITE_SITE_URL=https://www.webcentauri.com

# Lead notifications
LEAD_NOTIFY_EMAIL=support@webcentauri.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Database (Postgres 15+)
DATABASE_URL=postgres://webcentauri:CHANGE_ME@127.0.0.1:5432/webcentauri

# Session / CSRF — generate with: openssl rand -hex 32
SESSION_SECRET=